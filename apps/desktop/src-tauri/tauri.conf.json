{
  "productName": "Jot",
  "version": "0.1.2",
  "identifier": "com.ved.jot",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Jot",
        "width": 380,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "resources": {
      "icons/tray-iconTemplate.png": "icons/tray-iconTemplate.png",
      "icons/tray-iconTemplate@2x.png": "icons/tray-iconTemplate@2x.png"
    },
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
